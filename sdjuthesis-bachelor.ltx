  \endgroup
}

\RenewDocumentCommand\maketitle{}{%
  \pdfbookmark[0]{封面}{titlepage}
  \sdju@maketitle%
}
\newcommand{\sdju@maketitle}{%
  \cleardoublepage
  \thispagestyle{sdju@title}
  \begin{center}
    \vspace*{10mm}
    {\zihao{2}\bfseries\lishu 上海电机学院}

    \vskip 10mm
    {\zihao{2}\bfseries\lishu 学士学位论文}

    \vskip 15mm
    {\zihao{-2}\kaishu \sdju@value@title}

    \vskip \stretch{3}

    \begingroup
      \linespread{2.0}\selectfont\zihao{3}\songti
      \begin{tabular}{cl}
        学科专业：   & \sdju@value@major \\[3mm]
        学生姓名：   & \sdju@value@author \\[3mm]
        学\quad 号： & \sdju@value@studentid \\[3mm]
        指导教师：   & \sdju@value@supervisor \\[3mm]
        学\quad 院： & \sdju@value@college \\[3mm]
      \end{tabular}
    \endgroup

    \vskip \stretch{3}

    {\zihao{3}\songti \sdju@value@finisheddate}
  \end{center}
  \cleardoublepage
}
