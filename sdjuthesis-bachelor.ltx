\geometry{%
  paper      = a4paper,
  top        = 2.5cm,
  bottom     = 2.5cm,
  left       = 2.5cm,
  right      = 2.5cm,
  headheight = 1.0cm,
  headsep    = 0.5cm,
}

\fancypagestyle{sdju@title}{%
  \fancyhf{}
  \renewcommand{\headrulewidth}{0pt}
  \renewcommand{\footrulewidth}{0pt}
}
\fancypagestyle{sdju@plain}{%
  \fancyhf{}
  \fancyhead[C]{\zihao{-5}\sdju@label@schoolChi 毕业设计（论文）}
  \fancyfoot[C]{\small ~{\thepage}~}
}
\renewcommand{\frontmatter}{%
  \cleardoublepage
  \@mainmatterfalse
  \pagenumbering{Roman}
  \pagestyle{sdju@plain}
}
\renewcommand{\mainmatter}{%
  \cleardoublepage
  \@mainmattertrue
  \sdju@setfloatfonttrue
  \pagenumbering{arabic}
  \pagestyle{sdju@plain}
}
\renewcommand{\backmatter}{%
  \cleardoublepage
  \@mainmatterfalse
}

\renewcommand{\cftchapfont}{\bfseries\heiti}
\renewcommand{\cftchapleader}{\normalfont\cftdotfill{\cftdotsep}}

\NewDocumentEnvironment{abstract}{}{%
  \cleardoublepage
  \chapter*{%
    \begingroup
      \normalfont\zihao{3}\heiti\sdju@label@abstractChi
    \endgroup
  }
  \addcontentsline{toc}{chapter}{\sdju@label@abstractChi}
  \vskip 2ex
  \@mkboth{\sdju@label@abstractChi}%
          {\sdju@label@abstractChi}%
  \zihao{-4}
}{%
  \vskip 3ex \noindent
  \begingroup
    \heiti\sdju@label@keywordsChi
  \endgroup
  \begingroup
    \sdju@value@keywords
  \endgroup
}

\NewDocumentEnvironment{enabstract}{}{%
  \cleardoublepage
  \chapter*{%
    \begingroup
      \normalfont\zihao{3}\bfseries\sdju@label@abstractEng
    \endgroup
  }
