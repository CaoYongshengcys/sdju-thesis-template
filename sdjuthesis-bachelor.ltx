  \vskip 2ex
  \@mkboth{\sdju@label@abstractEng}%
          {\sdju@label@abstractEng}%
  \zihao{-4}
}{%
  \vskip 3ex \noindent
  \begingroup
    \bfseries\sdju@label@keywordsEng
  \endgroup
